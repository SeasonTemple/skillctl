#!/usr/bin/env sh
# nexel repo pre-commit: release-sync lint + the full test suite. The
# repo no longer ships a top-level skill catalog, so lint:skills /
# lint:manifest / lint:drift only apply when a downstream product wires
# them up — they are not run here. lint:release-sync IS repo-level (it
# guards package.json version == newest docs/release-notes/v*.md).
npm run --silent lint:release-sync
npm test --silent
